{
  "name": "dev-tools",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Java 开发工具箱",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"js/**/*.js\" \"css/**/*.css\" \"scripts/**/*.js\" \"test/**/*.js\" *.config.js *.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/copy-libs.js && vite build",
    "build:dev": "node scripts/copy-libs.js && vite build --mode dev",
    "preview": "vite preview",
    "copy-libs": "node scripts/copy-libs.js",
    "postinstall": "node scripts/copy-libs.js"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "asn1js": "^3.0.10",
    "bcryptjs": "^2.4.3",
    "blueimp-md5": "^2.19.0",
    "bootstrap-icons": "^1.13.1",
    "diff": "^5.2.0",
    "fast-xml-parser": "^4.5.6",
    "js-beautify": "^1.15.4",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^9.0.0",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "marked": "^12.0.2",
    "pkijs": "^3.4.0",
    "qrcode": "^1.5.4",
    "sm-crypto": "^0.3.14",
    "sql-formatter": "^15.4.0",
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
